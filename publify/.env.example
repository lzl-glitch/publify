# Application Configuration
APP_NAME=Publify
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
BASE_URL=http://localhost:8000

# Database
DATABASE_URL=sqlite:///./publify.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:port/database

# Redis
REDIS_URL=redis://localhost:6379/0

# Qiniu Cloud Storage (Development)
QINIU_ACCESS_KEY=your-qiniu-access-key
QINIU_SECRET_KEY=your-qiniu-secret-key
QINIU_BUCKET=your-bucket-name
QINIU_DOMAIN=https://cdn.example.com

# Xiaohongshu OAuth
XIAOHONGSHU_CLIENT_ID=your-xiaohongshu-client-id
XIAOHONGSHU_CLIENT_SECRET=your-xiaohongshu-client-secret
XIAOHONGSHU_REDIRECT_URI=http://localhost:8000/xiaohongshu/callback
XIAOHONGSHU_AUTH_URL=https://open.xiaohongshu.com/oauth/authorize
XIAOHONGSHU_TOKEN_URL=https://open.xiaohongshu.com/oauth/access_token

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Session Configuration
SESSION_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_ENABLED=true
